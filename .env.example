# Flask configuration
FLASK_APP=app.app:app
FLASK_ENV=development

# CRITICAL: Required security secrets (no defaults in production)
SECRET_KEY=your-production-secret-key-here
SECURITY_PASSWORD_SALT=your-production-salt-here

# Admin access control
# Set this to the single trusted staff owner account (typically your work email).
SUPER_ADMIN_EMAIL=admin@guecyber.com

# Database configuration
# For development, SQLite is used. For production, use PostgreSQL:
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@host:5432/gueinsight

# Frontend origins (CORS allowlist)
# Development:
# FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production:
# FRONTEND_ORIGINS=https://insights.guecyber.com

# Email configuration (optional, uses MAIL_USERNAME from ENV)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@guecyber.com
# MAIL_PASSWORD=your-app-specific-password
