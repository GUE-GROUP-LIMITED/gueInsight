# Production Environment Configuration Template
# Copy this to .env.production and fill in all values
# NEVER commit this file with real values to source control

# === CRITICAL: Flask & Security ===
SECRET_KEY=change-me-to-very-long-random-string-minimum-32-chars
SECURITY_PASSWORD_SALT=change-me-to-random-salt-for-password-hashing

# === Database ===
# SQLite: sqlite:///instance/app.db (NOT for production!)
# PostgreSQL: postgresql://user:password@localhost:5432/gueinsight
SQLALCHEMY_DATABASE_URI=postgresql://user:password@hostname:5432/gueinsight_prod

# === Session Security ===
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Strict
PERMANENT_SESSION_LIFETIME_SECONDS=86400

# === Email Configuration ===
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@guecyber.com

# === Stripe Payment Processing ===
STRIPE_API_KEY=sk_live_your_actual_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_actual_stripe_public_key_here

# === Supabase (Authentication & Database) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# === Data Residency & Compliance ===
EU_ONLY_DATA_RESIDENCY=true
PREFERRED_DATA_REGION=eu-west-1
DATA_RETENTION_DAYS=180
GDPR_POLICY_VERSION=2026-04
TERMS_VERSION=2026-04

# === Integrations (optional, enable as needed) ===

# Google Workspace
# GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@yourcompany.com
# GOOGLE_WORKSPACE_PRIVATE_KEY_ID=your-key-id
# GOOGLE_WORKSPACE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----...

# Microsoft 365
# MICROSOFT_365_TENANT_ID=your-tenant-id
# MICROSOFT_365_CLIENT_ID=your-client-id
# MICROSOFT_365_CLIENT_SECRET=your-client-secret

# RapidAPI
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_HOST=your-api-host

# === Application Settings ===
APP_ENV=production
FLASK_ENV=production
FLASK_DEBUG=false
LOG_LEVEL=INFO

# === Celery (Background Tasks) - Optional ===
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Monitoring & Logging (Optional) ===
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# DATADOG_API_KEY=your-datadog-api-key
# LOG_FILE=/var/log/gueinsight/app.log

# === Rate Limiting ===
RATELIMIT_ENABLED=true
RATELIMIT_LOGIN_ATTEMPTS=8
RATELIMIT_WINDOW_SECONDS=300

# === Security Headers ===
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
STRICT_TRANSPORT_SECURITY_MAX_AGE=31536000

# === Admin Settings ===
# ADMIN_EMAIL=admin@guecyber.com
# ADMIN_PASSWORD_HASH=generated-from-admin-hash-utility

# === Feature Flags (optional) ===
# FEATURE_NEW_DASHBOARD=true
# FEATURE_ADVANCED_ANALYTICS=true
